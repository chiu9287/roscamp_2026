<?xml version="1.0"?>
<robot name="arm_manipulator">

  <material name="robot_red"><color rgba="0.8 0.1 0.1 1.0"/></material>
  <material name="robot_white"><color rgba="0.9 0.9 0.9 1.0"/></material>
  <material name="robot_grey"><color rgba="0.3 0.3 0.3 1.0"/></material>

  <link name="base_link"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="arm_base_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry><cylinder radius="0.1" length="0.1"/></geometry>
      <material name="robot_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry><cylinder radius="0.1" length="0.1"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.006667" ixy="0.0" ixz="0.0" iyy="0.006667" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="arm_0_joint" type="revolute">
    <parent link="arm_base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="10.0" velocity="1.5" acceleration="2.0"/>
  </joint>

  <link name="link_1">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.3"/></geometry>
      <material name="robot_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.3"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.0079" ixy="0.0" ixz="0.0" iyy="0.0079" iyz="0.0" izz="0.0008"/>
    </inertial>
  </link>

  <joint name="arm_1_joint" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 0 0.3" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="10.0" velocity="1.5" acceleration="2.0"/>
  </joint>

  <link name="link_2">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><cylinder radius="0.035" length="0.3"/></geometry>
      <material name="robot_red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><cylinder radius="0.035" length="0.3"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <mass value="0.8"/>
      <inertia ixx="0.00624" ixy="0.0" ixz="0.0" iyy="0.00624" iyz="0.0" izz="0.00049"/>
    </inertial>
  </link>

  <joint name="arm_2_joint" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0 0 0.3" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0944" upper="2.0944" effort="10.0" velocity="1.5" acceleration="2.0"/>
  </joint>

  <link name="link_3">
    <visual>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry><cylinder radius="0.03" length="0.2"/></geometry>
      <material name="robot_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry><cylinder radius="0.03" length="0.2"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.00178" ixy="0.0" ixz="0.0" iyy="0.00178" iyz="0.0" izz="0.00023"/>
    </inertial>
  </link>

  <joint name="gripper_base_joint" type="fixed">
    <parent link="link_3"/>
    <child link="gripper_base_link"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
  </joint>

  <link name="gripper_base_link">
    <visual>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <geometry><box size="0.03 0.12 0.02"/></geometry>
      <material name="robot_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <geometry><box size="0.03 0.12 0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.000247" ixy="0.0" ixz="0.0" iyy="0.000022" iyz="0.0" izz="0.000255"/>
    </inertial>
  </link>

  <joint name="gripper_1_joint" type="prismatic">
    <parent link="gripper_base_link"/>
    <child link="gripper_finger_1"/>
    <origin xyz="0 0.04 0.02" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.03" upper="0.0" effort="5.0" velocity="0.1"/>
  </joint>

  <link name="gripper_finger_1">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><box size="0.02 0.01 0.05"/></geometry>
      <material name="robot_red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><box size="0.02 0.01 0.05"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.000011" ixy="0.0" ixz="0.0" iyy="0.000012" iyz="0.0" izz="0.000002"/>
    </inertial>
  </link>

  <joint name="gripper_2_joint" type="prismatic">
    <parent link="gripper_base_link"/>
    <child link="gripper_finger_2"/>
    <origin xyz="0 -0.04 0.02" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-0.03" upper="0.0" effort="5.0" velocity="0.1"/>
  </joint>

  <link name="gripper_finger_2">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><box size="0.02 0.01 0.05"/></geometry>
      <material name="robot_red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><box size="0.02 0.01 0.05"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.000011" ixy="0.0" ixz="0.0" iyy="0.000012" iyz="0.0" izz="0.000002"/>
    </inertial>
  </link>

</robot>