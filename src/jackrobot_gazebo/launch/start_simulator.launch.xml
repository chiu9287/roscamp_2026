<?xml version="1.0"?>
<launch>
    <let name="world_file" value="$(find-pkg-share jackrobot_gazebo)/worlds/empty.sdf" />

    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
        <arg name="gz_args" value="-s -r $(var world_file)"/>
    </include>

    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
        <arg name="gz_args" value="-g --render-engine ogre"/>
        <arg name="on_exit_shutdown" value="True"/>
    </include>

    <node pkg="ros_gz_bridge" exec="parameter_bridge" name="ros_gz_bridge" output="screen">
        <param name="config_file" value="$(find-pkg-share jackrobot_gazebo)/config/gz_bridge.yaml" type="str"/>
    </node>
</launch>
